# .env.example

# Database Configuration
DB_HOST=localhost
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Server Configuration
PORT=3000
NODE_ENV=development

# API Keys
API_KEY=your_api_key
ANOTHER_SERVICE_API_KEY=your_other_service_api_key

# Other Configuration
CUSTOM_SETTING=your_setting